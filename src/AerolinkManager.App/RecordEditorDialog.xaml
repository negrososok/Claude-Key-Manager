<Window x:Class="AerolinkManager.App.RecordEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit" Width="510" SizeToContent="Height" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="DescriptionText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,14"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="NameLabel" VerticalAlignment="Center"/><TextBox x:Name="NameBox" Grid.Column="1"/>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="IdLabel" VerticalAlignment="Center"/><TextBox x:Name="IdBox" Grid.Column="1"/>
        </Grid>
        <Grid x:Name="ProviderRow" Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="ProviderEditorLabel" VerticalAlignment="Center"/><ComboBox x:Name="ProviderBox" Grid.Column="1" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        </Grid>
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="ValueLabel" VerticalAlignment="Center"/><TextBox x:Name="ValueBox" Grid.Column="1"/>
        </Grid>
        <Grid x:Name="OptionRow" Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="OptionLabel" VerticalAlignment="Center"/><ComboBox x:Name="OptionBox" Grid.Column="1"/>
        </Grid>
        <Grid x:Name="ExtraRow" Grid.Row="6" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="ExtraLabel" VerticalAlignment="Center"/><TextBox x:Name="ExtraBox" Grid.Column="1"/>
        </Grid>
        <Grid x:Name="MoreRow" Grid.Row="7" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="MoreLabel" VerticalAlignment="Center"/><TextBox x:Name="MoreBox" Grid.Column="1"/>
        </Grid>
        <Grid x:Name="ModelModeRow" Grid.Row="8" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="ModelModeLabel" VerticalAlignment="Center"/><ComboBox x:Name="ModelModeBox" Grid.Column="1" DisplayMemberPath="Display" SelectedValuePath="Mode"/>
        </Grid>
        <DockPanel Grid.Row="9" Margin="0,10,0,0">
            <TextBlock x:Name="ValidationText" Foreground="#A33A3A" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="{DynamicResource Cancel}" Click="Cancel_Click" Margin="0,0,8,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="{DynamicResource Save}" Click="Save_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
